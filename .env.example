# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...        # public anon key (used in frontend)
SUPABASE_SERVICE_KEY=eyJ...     # service role key (used in worker, never exposed)

# Resend (email)
RESEND_API_KEY=re_...
EMAIL_FROM=recgov.me <alerts@recgov.me>

# Cloudflare Worker
WORKER_URL=https://recgovme.YOUR_SUBDOMAIN.workers.dev
